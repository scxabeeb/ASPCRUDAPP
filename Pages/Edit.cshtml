@page
@model EditModel

<h1>Update User Form</h1>
<form method="post">
    <div class="mt-3 card mb-3 p-3">
        <input type="hidden" asp-for="User.ID"/>
        <input type="text" placeholder="Enter Name" class="form-control mb-3" asp-for="User.Name" />
        <input type="text" placeholder="Enter Address" class="form-control mb-3" asp-for="User.Address" />
        <input type="date" class="form-control mb-3" asp-for="User.Date" />

        <select class="form-select mb-3" asp-for="User.Gender">
            <option value="Male">Male</option>
            <option value="Female">Female</option>
        </select>
        <button type="submit" class="btn btn-primary w-100">Update</button>
    </div>
</form>

