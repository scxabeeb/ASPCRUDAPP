@page
@model RegisterModel

<h1>Registeration Form</h1>
<form method="post">
<div class="mt-3 card mb-3 p-3">
        <input type="text" placeholder="Enter Name" class="form-control mb-3"  asp-for="Name"/>
        <input type="text" placeholder="Enter Address" class="form-control mb-3" asp-for="Address"/>
        <input type="date" class="form-control mb-3"  asp-for="Date"/>

        <select class="form-select mb-3" asp-for="Gender" >
<option value="Male">Male</option>
<option value="Female">Female</option>
</select>
<button type="submit" class="btn btn-primary w-100">Register</button>
</div>
</form>

